# Required ENV for vector search
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
DB_NAME=agriai
COLLECTION_NAME=questions
VECTOR_INDEX_NAME=review_questions_search_index
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# Golden Dataset source used by GET /gdb/gap-report.  When omitted, the
# reviewer Mongo URI is reused.
GOLDEN_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
GOLDEN_DB_NAME=golden_db
GOLDEN_QA_COLLECTION=agri_qa_latest

# Gemma LLM Endp    oint for Agent Search and Sanitization
GEMMA_LLM_ENDPOINT=http://100.100.108.44:8014/v1/chat/completions
