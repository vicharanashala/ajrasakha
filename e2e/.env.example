# ──────────────────────────────────────
# Ajrasakha E2E – environment variables
# ──────────────────────────────────────

# URL of the deployed app (or localhost for local dev)
STAGING_URL=http://localhost:5173

# Credentials for a dedicated test user with "expert" role
# Do NOT use real staff accounts — tests log in/out repeatedly.
E2E_EMAIL=test-expert@example.com
E2E_PASSWORD=TestPassword123!

# Optional: set to 1 to skip tests that need the Sarvam API live
# (language-switch tests use mocked API by default; set this to "live"
# if you want to use the real key instead)
SARVAM_TEST_MODE=mock
