/* ================================================================
   BADGE
================================================================ */

const badgeStyles: Record<BadgeVariant, React.CSSProperties> = {
  green: { background: "#EAF3DE", color: "#3B6D11" },
  red:   { background: "#FCEBEB", color: "#A32D2D" },
  amber: { background: "#FAEEDA", color: "#633806" },
  blue:  { background: "#E6F1FB", color: "#0C447C" },
};

interface BadgeProps {
  label: string;
  variant?: BadgeVariant;
}

function Badge({ label, variant = "green" }: BadgeProps) {
  return (
    <span
      style={{
        display: "inline-flex",
        alignItems: "center",
        padding: "2px 7px",
        borderRadius: 20,
        fontSize: 10,
        fontWeight: 500,
        ...badgeStyles[variant],
      }}
    >
      {label}
    </span>
  );
}

/* ================================================================
   SPARKLINE
================================================================ */

interface SparklineProps {
  points: number[];
  color: string;
}

function Sparkline({ points, color }: SparklineProps) {
  const max = Math.max(...points);
  const min = Math.min(...points);
  const W = 120;
  const H = 28;
  const px = (i: number): number => (i / (points.length - 1)) * W;
  const py = (v: number): number => H - ((v - min) / (max - min || 1)) * H;
  const d = points
    .map((v, i) => `${i === 0 ? "M" : "L"} ${px(i)} ${py(v)}`)
    .join(" ");
  const fill = `${d} L ${W} ${H} L 0 ${H} Z`;

  return (
    <svg
      viewBox={`0 0 ${W} ${H}`}
      style={{ width: "100%", height: 40 }}
      preserveAspectRatio="none"
    >
      <path d={fill} fill={color} fillOpacity={0.08} />
      <path
        d={d}
        fill="none"
        stroke={color}
        strokeWidth={1.5}
        strokeLinecap="round"
        strokeLinejoin="round"
      />
    </svg>
  );
}

/* ================================================================
   DELTA ICON
================================================================ */

interface DeltaIconProps {
  dir: DeltaDir;
}

function DeltaIcon({ dir }: DeltaIconProps) {
  if (dir === "up")
    return (
      <svg width={10} height={10} viewBox="0 0 10 10">
        <path d="M5 2l3 4H2z" fill="#1E7A3C" />
      </svg>
    );
  if (dir === "down")
    return (
      <svg width={10} height={10} viewBox="0 0 10 10">
        <path d="M5 8l3-4H2z" fill="#A32D2D" />
      </svg>
    );
  return <span style={{ fontSize: 10 }}>→</span>;
}

/* ================================================================
   KPI CARD
================================================================ */

interface KpiCardProps {
  kpi: KpiData;
}

function KpiCard({ kpi }: KpiCardProps) {
  const deltaColor =
    kpi.deltaDir === "up"
      ? "#1E7A3C"
      : kpi.deltaDir === "down"
      ? "#A32D2D"
      : "#888";

  return (
    <Card className="relative overflow-hidden flex-1 min-w-0">
      <div
        style={{
          position: "absolute",
          top: 0,
          left: 0,
          right: 0,
          height: 3,
          background: kpi.accentColor,
        }}
      />
      <CardContent className="px-4 pt-5 pb-4">
        <p
          style={{
            fontSize: 11,
            color: "#888",
            textTransform: "uppercase",
            letterSpacing: "0.4px",
            fontWeight: 500,
            marginBottom: 6,
            margin: 0,
          }}
        >
          {kpi.label}
        </p>
        <p
          style={{
            fontSize: 22,
            fontWeight: 500,
            color: kpi.valueColor ?? "#1a1a1a",
            lineHeight: 1,
            marginBottom: 4,
            margin: "6px 0 4px",
          }}
        >
          {kpi.value}
        </p>
        <div
          style={{
            fontSize: 11,
            display: "flex",
            alignItems: "center",
            gap: 3,
            color: deltaColor,
          }}
        >
          <DeltaIcon dir={kpi.deltaDir} />
          {kpi.delta}
        </div>
        {kpi.sparkPoints && (
          <div style={{ marginTop: 10 }}>
            <Sparkline points={kpi.sparkPoints} color={kpi.accentColor} />
          </div>
        )}
        {kpi.badges && (
          <div style={{ marginTop: 8, display: "flex", gap: 4, flexWrap: "wrap" }}>
            {kpi.badges.map((b) => (
              <Badge key={b.label} label={b.label} variant={b.variant} />
            ))}
          </div>
        )}
      </CardContent>
    </Card>
  );
}

/* ================================================================
   PROGRESS BAR
================================================================ */

interface ProgressBarProps {
  label: string;
  pct: number;
  color: string;
  valueColor?: string;
}

function ProgressBar({ label, pct, color, valueColor }: ProgressBarProps) {
  return (
    <div style={{ marginBottom: 10 }}>
      <div
        style={{
          display: "flex",
          justifyContent: "space-between",
          fontSize: 11,
          color: "#888",
          marginBottom: 4,
        }}
      >
        <span>{label}</span>
        <span style={{ color: valueColor ?? "#888", fontWeight: valueColor ? 500 : 400 }}>
          {pct}%
        </span>
      </div>
      <div style={{ height: 5, background: "#f0f0f0", borderRadius: 4, overflow: "hidden" }}>
        <div
          style={{
            width: `${pct}%`,
            height: "100%",
            background: color,
            borderRadius: 4,
            transition: "width 0.6s ease",
          }}
        />
      </div>
    </div>
  );
}

