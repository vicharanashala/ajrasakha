/* ================================================================
   TYPES
================================================================ */

type DeltaDir = "up" | "down" | "neutral";
type BadgeVariant = "green" | "red" | "amber" | "blue";
type AlertLevel = "critical" | "warn" | "info";

interface BadgeItem {
  label: string;
  variant: BadgeVariant;
}

interface KpiData {
  id: string;
  label: string;
  value: string;
  delta: string;
  deltaDir: DeltaDir;
  accentColor: string;
  valueColor?: string;
  sparkPoints?: number[];
  badges?: BadgeItem[];
}

interface FarmerSegment {
  id: string;
  label: string;
  users: string;
  status: string;
  statusVariant: BadgeVariant;
  description: string;
  dau: number;
  retention: number;
  queryRate: number;
  topCrop: string;
}

interface AlertItem {
  id: number;
  level: AlertLevel;
  title: string;
  desc: string;
}

interface ChannelSegment {
  label: string;
  pct: number;
  color: string;
}

interface VoiceAccuracy {
  lang: string;
  pct: number;
  color: string;
}

interface QueryCategory {
  label: string;
  pct: number;
  color: string;
  valueColor?: string;
}

interface GeoState {
  abbr: string;
  val: string;
  opacity: number;
}

interface HealthPillar {
  label: string;
  score: number;
  color: string;
}

interface DashboardMeta {
  season: string;
  lastSync: string;
  datasetVersion: string;
  llmVersion: string;
  p0Bugs: number;
}

interface DashboardData {
  meta: DashboardMeta;
  kpiRow1: KpiData[];
  kpiRow2: KpiData[];
  channelSplit: ChannelSegment[];
  voiceAccuracy: VoiceAccuracy[];
  queryCategories: QueryCategory[];
  farmerSegments: FarmerSegment[];
  alerts: AlertItem[];
  geoStates: GeoState[];
  healthPillars: HealthPillar[];
}

