================================================================ */

const alertStyles: Record<AlertLevel, { bg: string; border: string }> = {
  critical: { bg: "#FCEBEB", border: "#E24B4A" },
  warn:     { bg: "#FAEEDA", border: "#EF9F27" },
  info:     { bg: "#E6F1FB", border: "#3D8DE0" },
};

interface AlertItemRowProps {
  item: AlertItem;
}

function AlertItemRow({ item }: AlertItemRowProps) {
  const s = alertStyles[item.level];
  return (
    <div
      style={{
        background: s.bg,
        borderLeft: `3px solid ${s.border}`,
        borderRadius: 8,
        padding: "10px 12px",
        marginBottom: 7,
      }}
    >
      <p style={{ fontSize: 12, fontWeight: 500, color: "#1a1a1a", margin: 0 }}>
        {item.title}
      </p>
      <p style={{ fontSize: 11, color: "#666", marginTop: 2, lineHeight: 1.4, margin: 0 }}>
        {item.desc}
      </p>
    </div>
  );
}

/* ================================================================
   DONUT CHART
================================================================ */

interface DonutChartProps {
  segments: ChannelSegment[];
}

function DonutChart({ segments }: DonutChartProps) {
  const total = segments.reduce((s, x) => s + x.pct, 0);
  const r = 30;
  const cx = 40;
  const cy = 40;
  const circ = 2 * Math.PI * r;
  let offset = 0;

  return (
    <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
      <svg width={80} height={80} viewBox="0 0 80 80">
        <circle cx={cx} cy={cy} r={r} fill="none" stroke="#f0f0f0" strokeWidth={14} />
        {segments.map((seg) => {
          const dash = (seg.pct / total) * circ;
          const el = (
            <circle
              key={seg.label}
              cx={cx}
              cy={cy}
              r={r}
              fill="none"
              stroke={seg.color}
              strokeWidth={14}
              strokeDasharray={`${dash} ${circ - dash}`}
              strokeDashoffset={-offset}
              transform={`rotate(-90 ${cx} ${cy})`}
            />
          );
          offset += dash;
          return el;
        })}
        <text
          x={cx}
          y={cy + 4}
          textAnchor="middle"
          fontSize={11}
          fontWeight={500}
          fill="#1E7A3C"
        >
          {segments[0]?.pct}%
        </text>
      </svg>
      <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
        {segments.map((s) => (
          <div
            key={s.label}
            style={{ display: "flex", alignItems: "center", gap: 6, fontSize: 11, color: "#666" }}
          >
            <span
              style={{
                width: 8,
                height: 8,
                borderRadius: 2,
                background: s.color,
                flexShrink: 0,
                display: "inline-block",
              }}
            />
            {s.label} · {s.pct}%
          </div>
        ))}
      </div>
    </div>
  );
}

/* ================================================================
   SEGMENT DETAIL BANNER
================================================================ */

interface SegmentDetailBannerProps {
  seg: FarmerSegment;
  onClose: () => void;
}

type StatKey = "Users" | "Retention" | "Queries/day" | "Top crop";

interface SegmentStat {
  key: StatKey;
  val: string;
}

function SegmentDetailBanner({ seg, onClose }: SegmentDetailBannerProps) {
  const stats: SegmentStat[] = [
    { key: "Users", val: seg.users },
    { key: "Retention", val: `${seg.retention}%` },
    { key: "Queries/day", val: String(seg.queryRate) },
    { key: "Top crop", val: seg.topCrop },
  ];

  return (
    <div
      style={{
        background: "#EAF6EC",
        border: "1.5px solid #3AAA5A",
        borderRadius: 12,
        padding: "14px 16px",
        marginBottom: 16,
        display: "flex",
        gap: 24,
        alignItems: "flex-start",
      }}
    >
      <div style={{ flex: 1 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 6 }}>
          <span style={{ fontSize: 13, fontWeight: 500, color: "#1E7A3C" }}>
            {seg.label}
          </span>
          <Badge label={seg.status} variant={seg.statusVariant} />
        </div>
        <p style={{ fontSize: 11, color: "#3B6D11", marginBottom: 10 }}>
          {seg.description}
        </p>
        <div style={{ display: "flex", gap: 20, flexWrap: "wrap" }}>
          {stats.map(({ key, val }) => (
            <div key={key}>
              <div
                style={{
                  fontSize: 10,
                  color: "#3B6D11",
                  textTransform: "uppercase",
                  letterSpacing: "0.4px",
                }}
              >
                {key}
              </div>
              <div style={{ fontSize: 16, fontWeight: 500, color: "#1E7A3C" }}>{val}</div>
            </div>
          ))}
        </div>
      </div>
      <button
        onClick={onClose}
        aria-label="Close segment detail"
        style={{
          background: "none",
          border: "none",
          cursor: "pointer",
          color: "#3AAA5A",
          fontSize: 18,
          lineHeight: 1,
          padding: "0 4px",
        }}
      >
        ×
      </button>
    </div>
  );
}

