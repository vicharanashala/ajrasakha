/* ================================================================
   GEO COVERAGE CARD
================================================================ */

interface GeoCoverageCardProps {
  states: GeoState[];
}

function GeoCoverageCard({ states }: GeoCoverageCardProps) {
  return (
    <Card>
      <CardHeader className="pb-2">
        <CardTitle className="text-sm font-medium">Geographic concentration</CardTitle>
        <CardDescription>Active users by state · darker = higher</CardDescription>
      </CardHeader>
      <CardContent>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(6,1fr)", gap: 4 }}>
          {states.map((s) => (
            <div
              key={s.abbr}
              style={{
                borderRadius: 5,
                padding: "8px 6px",
                textAlign: "center",
                background: `rgba(30,122,60,${s.opacity})`,
              }}
            >
              <div
                style={{
                  fontSize: 11,
                  fontWeight: 500,
                  color: s.opacity > 0.5 ? "#fff" : "#0e4a22",
                }}
              >
                {s.abbr}
              </div>
              <div
                style={{
                  fontSize: 10,
                  opacity: 0.8,
                  marginTop: 2,
                  color: s.opacity > 0.5 ? "rgba(255,255,255,0.85)" : "#1e7a3c",
                }}
              >
                {s.val}
              </div>
            </div>
          ))}
        </div>
        <div
          style={{
            display: "flex",
            gap: 12,
            marginTop: 12,
            paddingTop: 10,
            borderTop: "0.5px solid #f0f0f0",
            fontSize: 11,
            color: "#888",
            flexWrap: "wrap",
          }}
        >
          <span>Top district: <strong style={{ color: "#1a1a1a" }}>Vidisha, MP</strong></span>
          <span>Fastest growing: <strong style={{ color: "#1E7A3C" }}>MP +62% MoM</strong></span>
          <span>Gap states: <strong style={{ color: "#A32D2D" }}>NE States &lt;200</strong></span>
        </div>
      </CardContent>
    </Card>
  );
}

/* ================================================================
   HEALTH SCORE CARD
================================================================ */

interface HealthScoreCardProps {
  pillars: HealthPillar[];
}

function HealthScoreCard({ pillars }: HealthScoreCardProps) {
  const composite = Math.round(
    pillars.reduce((sum, p) => sum + p.score, 0) / pillars.length
  );

  return (
    <Card>
      <CardHeader className="pb-2">
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
          <div>
            <CardTitle className="text-sm font-medium">Platform health score</CardTitle>
            <CardDescription>Six-pillar composite · weekly</CardDescription>
          </div>
          <div style={{ textAlign: "right" }}>
            <div style={{ fontSize: 26, fontWeight: 500, color: "#1E7A3C", lineHeight: 1 }}>
              {composite}
            </div>
            <div style={{ fontSize: 10, color: "#BA7517", fontWeight: 500 }}>MODERATE</div>
          </div>
        </div>
      </CardHeader>
      <CardContent>
        <div
          style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 8, marginBottom: 12 }}
        >
          {pillars.map((p) => (
            <div
              key={p.label}
              style={{ border: "0.5px solid #e5e5e5", borderRadius: 8, padding: 12, textAlign: "center" }}
            >
              <div
                style={{ fontSize: 20, fontWeight: 500, color: p.score >= 75 ? "#1E7A3C" : "#854F0B" }}
              >
                {p.score}
              </div>
              <div style={{ fontSize: 10, color: "#888", marginTop: 2 }}>{p.label}</div>
              <div
                style={{ height: 4, borderRadius: 2, background: "#f0f0f0", marginTop: 6, overflow: "hidden" }}
              >
                <div
                  style={{
                    width: `${p.score}%`,
                    height: "100%",
                    background: p.color,
                    borderRadius: 2,
                    transition: "width 0.6s ease",
                  }}
                />
              </div>
            </div>
          ))}
        </div>
        <div
          style={{ padding: 10, background: "#FAEEDA", borderRadius: 8, fontSize: 11, color: "#633806" }}
        >
          <span style={{ fontWeight: 500 }}>Action needed:</span> Geo reach + Retention
          below 65 — assign sprint owners this week
        </div>
      </CardContent>
    </Card>
  );
}

/* ================================================================
   STATUS BAR
================================================================ */

interface StatusBarProps {
  meta: DashboardMeta;
}

function Divider() {
  return (
    <span
      style={{ width: 1, height: 12, background: "#e5e5e5", display: "inline-block" }}
    />
  );
}

function StatusBar({ meta }: StatusBarProps) {
  const items: Array<{ label: string; value: string }> = [
    { label: "Last sync", value: meta.lastSync },
    { label: "Dataset", value: meta.datasetVersion },
    { label: "Agri-LLM", value: meta.llmVersion },
  ];

  return (
    <div
      style={{
        background: "#fff",
        borderTop: "0.5px solid #e5e5e5",
        display: "flex",
        alignItems: "center",
        gap: 16,
        padding: "8px 20px",
        fontSize: 11,
        color: "#aaa",
        flexShrink: 0,
        flexWrap: "wrap",
      }}
    >
      <span
        style={{ width: 6, height: 6, borderRadius: "50%", background: "#3AAA5A", display: "inline-block" }}
      />
      <span>All systems operational</span>
      {items.map(({ label, value }) => (
        <>
          <Divider key={`div-${label}`} />
          <span key={label}>{label}: {value}</span>
        </>
      ))}
      <Divider />
      <span style={{ color: "#A32D2D", fontWeight: 500 }}>
        {meta.p0Bugs} P0 bugs open · action required
      </span>
    </div>
  );
}

/* ================================================================
   SIDEBAR HELPERS
================================================================ */

interface SidebarNavItemProps {
  label: string;
  active?: boolean;
  indent?: boolean;
  isActiveSegment?: boolean;
  badge?: string;
  badgeAmber?: boolean;
  onClick?: () => void;
}

function SidebarNavItem({
  label,
  active = false,
  indent = false,
  isActiveSegment = false,
  badge,
  badgeAmber = false,
  onClick,
}: SidebarNavItemProps) {
  const highlighted = active || isActiveSegment;
  return (
    <div
      onClick={onClick}
      role={onClick ? "button" : undefined}
      tabIndex={onClick ? 0 : undefined}
      style={{
        display: "flex",
        alignItems: "center",
        gap: 9,
        padding: "8px 16px",
        paddingLeft: indent ? 32 : 16,
        cursor: onClick ? "pointer" : "default",
        fontSize: 13,
        borderLeft: `2px solid ${highlighted ? "#3AAA5A" : "transparent"}`,
        background: active ? "#EAF6EC" : isActiveSegment ? "#f0faf2" : "transparent",
        color: highlighted ? "#1E7A3C" : "#666",
        fontWeight: highlighted ? 500 : 400,
        transition: "all 0.15s",
      }}
    >
      <span style={{ flex: 1 }}>{label}</span>
      {badge && (
        <span
          style={{
            fontSize: 10,
            fontWeight: 500,
            padding: "1px 5px",
            borderRadius: 10,
            background: badgeAmber ? "#BA7517" : "#E24B4A",
            color: "#fff",
          }}
        >
          {badge}
        </span>
      )}
    </div>
  );
}

function SidebarLabel({ children }: { children: React.ReactNode }) {
  return (
    <div
      style={{
        fontSize: 10,
        fontWeight: 500,
        color: "#aaa",
        padding: "0 16px",
        margin: "16px 0 6px",
        textTransform: "uppercase",
        letterSpacing: "0.6px",
      }}
    >
      {children}
    </div>
  );
}

/* ================================================================
   MAIN DASHBOARD EXPORT
================================================================ */

import { DashboardFilters, type DashboardFilterValues } from "./DashboardFilters";

export function AnnamDashboard() {
  const [activeSegment, setActiveSegment] = useState<FarmerSegment | null>(null);
  const [sidebarSegmentsOpen, setSidebarSegmentsOpen] = useState<boolean>(false);

  // ─── FILTER STATE for dynamic subtitle ───────────────────────────────────
  const [activeFilters, setActiveFilters] = useState<DashboardFilterValues>({
    village: "all",
    crop: "all",
    season: "all",
  });

  const segmentsRef = useRef<HTMLDivElement>(null);
  const segmentRowRefs = useRef<Record<string, HTMLTableRowElement | null>>({});

  const data: DashboardData = DASHBOARD_DATA;

  const handleSegmentClick = useCallback(
    (seg: FarmerSegment): void => {
      if (activeSegment?.id === seg.id) {
        setActiveSegment(null);
        return;
      }
      setActiveSegment(seg);
      setSidebarSegmentsOpen(true);
      setTimeout(() => {
        segmentsRef.current?.scrollIntoView({ behavior: "smooth", block: "center" });
      }, 50);
    },
    [activeSegment]
  );

  const handleSidebarSegmentClick = useCallback(
    (seg: FarmerSegment): void => {
      handleSegmentClick(seg);
      setTimeout(() => {
        segmentRowRefs.current[seg.id]?.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
        });
      }, 350);
    },
    [handleSegmentClick]
  );

  const clearSegment = useCallback((): void => setActiveSegment(null), []);

  const criticalCount = data.alerts.filter((a) => a.level === "critical").length;

  return (
    <div
      style={{
        fontFamily: "'DM Sans', 'Inter', system-ui, sans-serif",
        background: "#f5f5f3",
        minHeight: "100vh",
        display: "flex",
        flexDirection: "column",
      }}
    >
      {/* ── TOP NAV ─────────────────────────────────────── */}
      <header
        style={{
          background: "#0F4A24",
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          padding: "0 20px",
          height: 52,
          flexShrink: 0,
        }}
      >
        <div style={{ display: "flex", alignItems: "center", gap: 14 }}>
          <span
            style={{
              background: "#3AAA5A",
              color: "#fff",
              fontSize: 13,
              fontWeight: 500,
              padding: "4px 10px",
              borderRadius: 6,
            }}
          >
            ACE
          </span>
          <span style={{ color: "rgba(255,255,255,0.85)", fontSize: 13, fontWeight: 500 }}>
            ANNAM.AI · Agri Intelligence Platform
          </span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          <span
            style={{
              display: "flex",
              alignItems: "center",
              gap: 5,
              background: "rgba(74,220,100,0.15)",
              color: "#4adc64",
              fontSize: 11,
              fontWeight: 500,
              padding: "3px 9px",
              borderRadius: 20,
            }}
          >
            <span style={{ width: 5, height: 5, background: "#4adc64", borderRadius: "50%" }} />
            Live
          </span>
          <span style={{ color: "rgba(255,255,255,0.45)", fontSize: 11 }}>
            {data.meta.season} · Q3
          </span>
          <div
            style={{
              width: 28,
              height: 28,
              borderRadius: "50%",
              background: "#1E7A3C",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              color: "#fff",
              fontSize: 11,
              fontWeight: 500,
            }}
          >
            PK
          </div>
        </div>
      </header>

      {/* ── BODY ────────────────────────────────────────── */}
      <div style={{ display: "flex", flex: 1, overflow: "hidden" }}>

        {/* SIDEBAR */}
        <nav
          style={{
            width: 210,
            background: "#fff",
            borderRight: "0.5px solid #e5e5e5",
            flexShrink: 0,
            overflowY: "auto",
            padding: "16px 0 80px",
            position: "relative",
          }}
        >
          <SidebarLabel>Core views</SidebarLabel>
          <SidebarNavItem label="Overview" active />
          <SidebarNavItem
            label="Farmer segments"
            onClick={() => setSidebarSegmentsOpen((o) => !o)}
          />
          {sidebarSegmentsOpen &&
            data.farmerSegments.map((seg) => (
              <SidebarNavItem
                key={seg.id}
                label={seg.label}
                indent
                isActiveSegment={activeSegment?.id === seg.id}
                onClick={() => handleSidebarSegmentClick(seg)}
              />
            ))}
          <SidebarNavItem label="Usage patterns" />
          <SidebarNavItem label="Geo intelligence" />

          <SidebarLabel>Quality</SidebarLabel>
          <SidebarNavItem label="Feedback & sentiment" />
          <SidebarNavItem label="Bugs & UX issues" badge="7" />

          <SidebarLabel>Intelligence</SidebarLabel>
          <SidebarNavItem label="Query analysis" badge="28%" badgeAmber />
          <SidebarNavItem label="App health score" />

          {/* Health score pinned widget */}
          <div
            style={{
              position: "absolute",
              bottom: 0,
              left: 0,
              width: 210,
              padding: "12px 16px",
              borderTop: "0.5px solid #e5e5e5",
              background: "#fff",
            }}
          >
            <div style={{ fontSize: 11, color: "#aaa" }}>Health score</div>
            <div style={{ display: "flex", alignItems: "center", gap: 8, marginTop: 4 }}>
              <div style={{ flex: 1, height: 4, background: "#f0f0f0", borderRadius: 2, overflow: "hidden" }}>
                <div style={{ width: "70%", height: "100%", background: "#3AAA5A", borderRadius: 2 }} />
              </div>
              <span style={{ fontSize: 12, fontWeight: 500, color: "#1E7A3C" }}>70</span>
            </div>
            <div style={{ fontSize: 10, color: "#BA7517", marginTop: 2 }}>
              Moderate · needs improvement
            </div>
          </div>
        </nav>

        {/* MAIN */}
        <main style={{ flex: 1, overflowY: "auto", padding: 20 }}>

          <DashboardFilters onFilterChange={setActiveFilters} />

          {/* Segment detail banner */}
          {activeSegment !== null && (
            <SegmentDetailBanner seg={activeSegment} onClose={clearSegment} />
          )}

          {/* KPI row 1 */}
          <div
            style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: 10, marginBottom: 10 }}
          >
            {data.kpiRow1.map((k) => <KpiCard key={k.id} kpi={k} />)}
          </div>

          {/* KPI row 2 */}
          <div
            style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: 10, marginBottom: 16 }}
          >
            {data.kpiRow2.map((k) => <KpiCard key={k.id} kpi={k} />)}
          </div>

          {/* DAU chart + Channel split */}
          <div
            style={{ display: "grid", gridTemplateColumns: "2fr 1fr", gap: 10, marginBottom: 16 }}
          >
            <DauTrendChart />
            <Card>
              <CardHeader className="pb-2">
                <CardTitle className="text-sm font-medium">Channel split</CardTitle>
                <CardDescription>How farmers access ACE</CardDescription>
              </CardHeader>
              <CardContent>
                <DonutChart segments={data.channelSplit} />
                <div style={{ marginTop: 14, paddingTop: 10, borderTop: "0.5px solid #f0f0f0" }}>
                  <p style={{ fontSize: 11, color: "#888", marginBottom: 8, fontWeight: 500, margin: 0 }}>
                    Voice accuracy by language
                  </p>
                  {data.voiceAccuracy.map((v) => (
                    <ProgressBar key={v.lang} label={v.lang} pct={v.pct} color={v.color} />
                  ))}
                </div>
              </CardContent>
            </Card>
          </div>

          {/* 3-col row */}
          <div
            style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 10, marginBottom: 16 }}
          >
            {/* Query categories */}
            <Card>
              <CardHeader className="pb-2">
                <CardTitle className="text-sm font-medium">Query categories</CardTitle>
                <CardDescription>This week · all channels</CardDescription>
              </CardHeader>
              <CardContent>
                {data.queryCategories.map((q) => (
                  <ProgressBar
                    key={q.label}
                    label={q.label}
                    pct={q.pct}
                    color={q.color}
                    valueColor={q.valueColor}
                  />
                ))}
                <div
                  style={{ marginTop: 10, paddingTop: 10, borderTop: "0.5px solid #f0f0f0" }}
                >
                  <p style={{ fontSize: 11, color: "#888", margin: 0 }}>Top unanswered cluster</p>
                  <p style={{ fontSize: 12, fontWeight: 500, color: "#A32D2D", marginTop: 2, margin: 0 }}>
                    Mandi pricing · 8,400 queries
                  </p>
                </div>
              </CardContent>
            </Card>

            {/* Farmer segments — interactive */}
            <Card
              ref={segmentsRef}
              style={{
                transition: "box-shadow 0.3s",
                boxShadow: activeSegment
                  ? "0 0 0 2.5px #3AAA5A, 0 4px 24px rgba(58,170,90,0.18)"
                  : undefined,
              }}
            >
              <CardHeader className="pb-2">
                <div
                  style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between" }}
                >
                  <div>
                    <CardTitle className="text-sm font-medium">Farmer segments</CardTitle>
                    <CardDescription>
                      {activeSegment !== null
                        ? `Viewing: ${activeSegment.label}`
                        : "Click a row to inspect segment"}
                    </CardDescription>
                  </div>
                  {activeSegment !== null && (
                    <button
                      onClick={clearSegment}
                      style={{
                        fontSize: 11, color: "#888", background: "none",
                        border: "0.5px solid #ddd", borderRadius: 6,
                        padding: "3px 8px", cursor: "pointer",
                      }}
                    >
                      Clear
                    </button>
                  )}
                </div>
              </CardHeader>
              <CardContent className="p-0">
                <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12 }}>
                  <thead>
                    <tr style={{ background: "#fafafa" }}>
                      {(["Segment", "Users", "Status"] as const).map((h) => (
                        <th
                          key={h}
                          style={{
                            textAlign: "left", fontSize: 10, fontWeight: 500,
                            color: "#aaa", textTransform: "uppercase",
                            letterSpacing: "0.4px", padding: "6px 16px",
                            borderBottom: "0.5px solid #f0f0f0",
                          }}
                        >
                          {h}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {data.farmerSegments.map((seg) => (
                      <tr
                        key={seg.id}
                        ref={(el: HTMLTableRowElement | null) => {
                          segmentRowRefs.current[seg.id] = el;
                        }}
                        onClick={() => handleSegmentClick(seg)}
                        style={{
                          cursor: "pointer",
                          background:
                            activeSegment?.id === seg.id ? "#EAF6EC" : "transparent",
                          transition: "background 0.2s",
                        }}
                      >
                        <td
                          style={{
                            padding: "9px 16px",
                            borderBottom: "0.5px solid #f0f0f0",
                            fontWeight: activeSegment?.id === seg.id ? 500 : 400,
                          }}
                        >
                          <span style={{ display: "flex", alignItems: "center", gap: 6 }}>
                            {activeSegment?.id === seg.id && (
                              <span
                                style={{
                                  width: 6, height: 6, borderRadius: "50%",
                                  background: "#3AAA5A", flexShrink: 0,
                                  display: "inline-block",
                                }}
                              />
                            )}
                            {seg.label}
                          </span>
                        </td>
                        <td style={{ padding: "9px 16px", borderBottom: "0.5px solid #f0f0f0" }}>
                          {seg.users}
                        </td>
                        <td style={{ padding: "9px 16px", borderBottom: "0.5px solid #f0f0f0" }}>
                          <Badge label={seg.status} variant={seg.statusVariant} />
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </CardContent>
            </Card>

            {/* Alerts */}
            <Card>
              <CardHeader className="pb-2">
                <div
                  style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}
                >
                  <CardTitle className="text-sm font-medium">Active alerts</CardTitle>
                  <Badge label={`${criticalCount} critical`} variant="red" />
                </div>
                <CardDescription>Requires leadership action</CardDescription>
              </CardHeader>
              <CardContent>
                {data.alerts.map((a) => (
                  <AlertItemRow key={a.id} item={a} />
                ))}
              </CardContent>
            </Card>
          </div>

          {/* Geo + Health */}
          <div style={{ display: "grid", gridTemplateColumns: "repeat(2,1fr)", gap: 10 }}>
            <GeoCoverageCard states={data.geoStates} />
            <HealthScoreCard pillars={data.healthPillars} />
          </div>
        </main>
      </div>

      {/* STATUS BAR */}
      <StatusBar meta={data.meta} />
    </div>
  );
}
