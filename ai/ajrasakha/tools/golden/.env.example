# Copy to .env and fill in values:
#   cp .env.example .env

# Embedding service endpoint
GOLDEN_EMBEDDING_ENDPOINT=http://your-embedding-service:6001/embed
GOLDEN_EMBEDDING_TIMEOUT_S=15

GOLDEN_MONGODB_URI=mongodb+srv://lpulga167_db_user:UUXFvuymiWUfMeT3@hackathon.idfnza4.mongodb.net/?retryWrites=true&w=majority&appName=hackathon
GOLDEN_MONGODB_DATABASE=agriai
GOLDEN_MONGODB_INDEX=questions_vector_index
GOLDEN_MONGODB_SEARCH_INDEX=questions_search_index

# RAG configuration
GOLDEN_RAG_TOP_K=5

# V2 API Dual Search Configuration
# Dual search: searches both question_embedding and answer_embedding in parallel
# Requires dual index with both embeddings on the same collection
GOLDEN_MONGODB_DUAL_EMBEDDING_INDEX=dual_embedding_vector_index
GOLDEN_MONGODB_QUESTION_EMBEDDING_INDEX=question_embedding_vector_index
QUESTIONS_TOP_K=3
ANSWERS_TOP_K=2

# BM25 Keyword Search Configuration
# Used in V2 API combined search pipeline (3.2)
BM25_TOP_K=3
BM25_SEARCH_INDEX=questions_search_index

# Gemma classifier configuration
GEMMA_MODEL=google/gemma-4-26B-A4B-it
GEMMA_BASE_URL=http://your-gemma-service:8013/v1
GOLDEN_GEMMA_TIMEOUT_S=30
GOLDEN_TIE_BREAK_MIN=2