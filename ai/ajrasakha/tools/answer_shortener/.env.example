# Required Claude credential. Never commit a real key.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default source-segment ranking model.
ANSWER_SHORTENER_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_RETRIES=2

# One initial ranking attempt plus up to two corrective attempts.
ANSWER_SHORTENER_REWRITE_ATTEMPTS=3
ANSWER_SHORTENER_MAX_OUTPUT_TOKENS=32768

# Optional locally. Set this in deployment to require X-API-Key on the shorten route.
ANSWER_SHORTENER_API_KEY=

# Docker host port; compose publishes it on 127.0.0.1 only.
ANSWER_SHORTENER_HOST_PORT=8112
