# OpenAI Configuration
OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://100.100.108.100:8080/v1

# OpenWeather API Configuration
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Golden RAG Tool Configuration
GOLDEN_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
GOLDEN_EMBEDDING_ENDPOINT=http://100.100.108.43:6001/embed
GOLDEN_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
GOLDEN_MONGODB_INDEX=review_questions_vector_index
GOLDEN_MONGODB_DATABASE=agriai
GOLDEN_MONGODB_COLLECTION=questions
GOLDEN_MONGODB_SEARCH_INDEX=review_questions_search_index
GOLDEN_CROP_MASTER_COLLECTION=crop_master
# Literal Python dict module (Mongo sync → crop_chemical_name.py → memory). Rebuild:
# python -m ajrasakha.agents.build_crop_master_dictionary
GOLDEN_CROP_CHEMICAL_NAME_PATH=ajrasakha/agents/crop_chemical_name.py

# Per-thread log files: logs/{thread_id}.txt (disable with THREAD_FILE_LOGGING=false)
THREAD_LOG_DIR=logs
THREAD_FILE_LOGGING=true

# Agricultural API Base URLs
AGMARKNET_BASE_URL=https://api.agmarknet.gov.in/v1
ENAM_BASE_URL=https://enam.gov.in/web/Ajax_ctrl

# IMD Weather Service Configuration
IMD_CITY_BASE=http://100.100.108.101:18080/city/api
IMD_MAUSAM_BASE=http://100.100.108.101:18080/mausam/api

# WhatsApp & Graph Database Configurations
WHATSAPP_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/whatsapp
DATABASE_URI=postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# Gemma Model Configuration
GEMMA_MODEL=google/gemma-4-26B-A4B-it
GEMMA_BASE_URL=http://100.100.108.44:8013/v1

# Remote MCP / Golden API
REMOTE_IP=100.100.108.44
# Base URL only (not .../v1/gdb/search). Docker compose often maps 8110:8005.
GOLDEN_API_URL=http://100.100.108.41:8110
GOLDEN_API_TIMEOUT_S=120
GOLDEN_RAG_TOP_K=5
GOLDEN_GEMMA_TIMEOUT_S=30
# LLM tie-breaker when this many or more share SAME_INTENT or COVERED_BY_CONTEXT (default 2)
GOLDEN_TIE_BREAK_MIN=2

# Reviewer question channel when LangGraph configurable.question_source is not set
QUESTION_SOURCE=AJRASAKHA
