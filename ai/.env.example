# OpenWeather API Configuration
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Golden RAG Tool Configuration
GOLDEN_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GOLDEN_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
GOLDEN_MONGODB_DATABASE=your_database_name
GOLDEN_MONGODB_COLLECTION=your_collection_name
GOLDEN_MONGODB_INDEX=your_vector_index_name

# HuggingFace Cache (Optional)
HUGGINGFACE_HUB_CACHE=/path/to/huggingface/cache
