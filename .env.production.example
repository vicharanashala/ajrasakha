# =============================================================================
# Ajrasakha — Production environment variables
# =============================================================================
# Copy this file to .env.production before running:
#     cp .env.production.example .env.production
# and replace every placeholder.
# This file is loaded by docker-compose.production.yml.
# =============================================================================

# ---------------------------------------------------------------------------
# Node / runtime
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=4000

# Backend replica identifiers (each container gets its own)
INSTANCE_ID=backend-1

# ---------------------------------------------------------------------------
# MongoDB (replica set rs0)
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://mongo-primary:27017,mongo-secondary-1:27017,mongo-secondary-2:27017/ajrasakha?replicaSet=rs0&w=majority&readPreference=primaryPreferred
MONGO_DB=ajrasakha
# Optional separate read replica URI — points to secondaries for analytics
MONGO_READ_URI=mongodb://mongo-secondary-1:27017,mongo-secondary-2:27017/ajrasakha?replicaSet=rs0&readPreference=secondaryPreferred

# ---------------------------------------------------------------------------
# Redis (cache + sessions + rate-limit counters)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=please-replace-with-a-64-char-random-string
JWT_ACCESS_TTL=900           # 15 min
JWT_REFRESH_TTL=2592000      # 30 days

# ---------------------------------------------------------------------------
# Firebase (admin SDK)
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=

# ---------------------------------------------------------------------------
# Frontend (build-time — injected via ARG in frontend Dockerfile)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_SARVAM_API_KEY=
VITE_VAPID_PUBLIC_KEY=
VITE_ENABLE_MOCKS=false

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------
FAQ_API_URL=
POP_API_URL=
SARVAM_API_KEY=
OLLAMA_BASE_URL=

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05

# ---------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated)
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://desk.vicharanashala.ai,https://ajrasakha.vicharanashala.ai

# ---------------------------------------------------------------------------
# Tailscale (private mesh between API services — optional)
# ---------------------------------------------------------------------------
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=