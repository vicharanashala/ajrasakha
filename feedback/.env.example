# Farmer Feedback System — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Original cluster - READ ONLY (provided by ACE team)
ORIGINAL_DB_URL=mongodb+srv://<user>:<password>@<cluster>
ORIGINAL_DB_NAME=agriai

# Your own cluster - READ + WRITE (your MongoDB Atlas free tier)
OWN_DB_URL=mongodb+srv://<user>:<password>@<cluster>
OWN_DB_NAME=feedback


# SMTP - for weekly digest email 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<gmail-app-password>
DIGEST_RECIPIENT_EMAIL=<agri-team-email>
# Reviewer pipeline integration (V1.2)
# Set these when the team provides service account credentials
REVIEWER_BASE_URL=https://desk.vicharanashala.ai
REVIEWER_AUTH_TOKEN=<service-account-bearer-token>

# Flagging thresholds
FLAGGING_THRESHOLD=60.0
MIN_RESPONSES_TO_FLAG=10
