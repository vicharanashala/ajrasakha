# Farmer Feedback System — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Original cluster - READ ONLY (provided by ACE team)
ORIGINAL_DB_URL=mongodb+srv://<user>:<password>@<cluster>
ORIGINAL_DB_NAME=agriai

# Your own cluster - READ + WRITE (your MongoDB Atlas free tier)
OWN_DB_URL=mongodb+srv://<user>:<password>@<cluster>
OWN_DB_NAME=feedback


# SMTP - for weekly digest email 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<gmail-app-password>
DIGEST_RECIPIENT_EMAIL=<agri-team-email>