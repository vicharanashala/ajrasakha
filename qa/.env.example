# =============================================================================
# Reviewer System — local QA environment variables
# =============================================================================
# Copy this file to qa/.env and fill in real values.  The qa/.env* files are
# git-ignored; never commit real secrets.
#
# Naming
# ------
# The PR #1 (this PR) suite prefers the friendlier names below.  The legacy
# REVIEWER_* names still work as fallbacks so existing CI secrets do not need
# to be rotated.
# =============================================================================

# --- Staging ---------------------------------------------------------------
# The Reviewer System staging URL (desk.vicharanashala.ai in production).
REVIEWER_STAGING_URL=https://desk.ajrasakha.in

# --- Moderator test account ------------------------------------------------
MODERATOR_TEST_EMAIL=moderator@example.com
MODERATOR_TEST_PASSWORD=replace-me

# --- Expert test accounts --------------------------------------------------
# A second expert can be used for re-allocation tests.
EXPERT_TEST_EMAIL=expert.one@example.com
EXPERT_TEST_PASSWORD=replace-me
EXPERT_TEST_2_EMAIL=expert.two@example.com
EXPERT_TEST_2_PASSWORD=replace-me

# --- Reviewer test account (peer-review role — PR #2) ---------------------
REVIEWER_TEST_EMAIL=reviewer@example.com
REVIEWER_TEST_PASSWORD=replace-me

# --- Coordinator test account (PR #3) -------------------------------------
COORDINATOR_TEST_EMAIL=coordinator@example.com
COORDINATOR_TEST_PASSWORD=replace-me

# --- Web-app staging -------------------------------------------------------
# Used by tests/web-app/* (separate project in playwright.config.ts).
WEBAPP_BASE_URL=https://ajrasakha.in
WEBAPP_FARMER_PHONE=+911234567890
WEBAPP_OTP=123456

# =============================================================================
# CI DEPLOYMENT — only set in GitHub Secrets or your local overrides
# =============================================================================
# CI also exports the legacy REVIEWER_BASE_URL / REVIEWER_MODERATOR_EMAIL /
# REVIEWER_EXPERT_EMAIL / REVIEWER_REVIEWER_EMAIL / REVIEWER_COORDINATOR_EMAIL
# names; the loader keeps both working.  When CI is migrated to the new names,
# remove the legacy GitHub Secrets in one PR so the rest of the team can
# track which variables are still expected.
# =============================================================================