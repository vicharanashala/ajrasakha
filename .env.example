# Copy to .env and fill in values:
#   cp .env.example .env
#
# Run the app stack (build locally):
#   docker compose -f docker-compose.app.yml up --build
#
# Portainer / pull-only (VITE_* passed as stack env → runtime-config.js in container):
#   docker compose -f docker-compose.pull.yml pull
#   docker compose -f docker-compose.pull.yml up -d
#
# SSH build frontend locally (not Portainer):
#   docker compose --env-file .env.deployed -f docker-compose.pull-build.yml up -d --build
#
# GCP service account: keep the JSON file on the host (not in the image).
# Set GCP_CREDENTIALS_HOST_PATH to its location; compose mounts it read-only.

# --- Docker Hub (docker-compose.pull.yml only) ---
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# --- Docker / GCP credentials ---
# Host path (install once: sudo cp backend/gcp-service-account.json /opt/reviewer/secrets/)
GCP_CREDENTIALS_HOST_PATH=/opt/reviewer/secrets/gcp-service-account.json
# Path inside the backend container (do not change unless you change the volume mount)
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json

# --- Ports (docker-compose.app.yml / docker-compose.pull.yml) ---
# APP_PORT — API listens on this port inside reviewer-backend; nginx proxies here too
APP_PORT=4000
# BACKEND_HOST_PORT — port on the host machine for direct API access (optional; defaults to APP_PORT)
BACKEND_HOST_PORT=4000
# FRONTEND_PORT — port on the host for the web UI
FRONTEND_PORT=8080

# --- Backend: app ---
NODE_ENV=production
APP_MODULE=all
APP_URL=http://localhost:8080
APP_ORIGINS=http://localhost:8080
APP_ROUTE_PREFIX=/api
FRONTEND_URL=http://localhost:8080
ADMIN_PASSWORD=

# --- Gap Detector ---
GAP_DETECTOR_PORT=8000
VITE_GAP_DETECTOR_API_URL=http://localhost:8000

# --- Backend: database ---
DB_URL=mongodb+srv://<user>:<password>@<cluster>/?appName=<name>
DB_NAME=
SKIP_DB_CONNECTION=

# --- Backend: analytics database ---
DB_URL_ANALYTICS=
DB_NAME_ANALYTICS=
ANNAM_URL_ANALYTICS=
ANNAM_DB_ANALYTICS=

# --- Backend: Firebase Admin (server) ---
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_STORAGE_BUCKET=

# Firebase emulators (local dev only)
FIREBASE_AUTH_EMULATOR_HOST=
FIREBASE_EMULATOR_HOST=
GCLOUD_PROJECT=

# --- Backend: GCP backups ---
GCP_BACKUP_BUCKET=
ENABLE_DB_BACKUP=false

# --- Backend: storage (optional) ---
GOOGLE_ANOMALY_BUCKET=
GOOGLE_FACES_BUCKET=
GOOGLE_AI_SERVER_BUCKET=
MEDIA_ENCRYPTION_KEY=

# --- Backend: AI / upstream ---
ENABLE_AI_SERVER=false
AI_SERVER_IP=
AI_SERVER_PORT=
AGENT_SERVER_IP=
AGENT_SERVER_PORT=
AI_PROXY_ADDRESS=
OPENAI_SERVER_IP=
OPENAI_SERVER_PORT=
WHATSAPP_SERVER_PORT=
GEMMA_API=
GEMMA_API_KEY=
LANGRAPH_SERVER_IP=
LANGRAPH_SERVER_PORT=
SARVAM_API_KEY=

# --- Backend: webhooks / internal API ---
INTERNAL_API_KEY=
WA_WEBHOOK_API_URL=
WA_WEBHOOK_API_KEY=
WA_SEND_MESSAGE_WEBHOOK_API_URL=
WEB_WEBHOOK_API_URL=
WEB_WEBHOOK_API_KEY=

# --- Backend: email ---
EMAIL_USER=
EMAIL_PASS=
BACKUP_NOTIFICATION_EMAIL=
SMTP_USER=
SMTP_PASS=

# --- Backend: push notifications ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# --- Backend: observability ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Frontend (VITE_* — baked into the image at build time) ---
VITE_ENABLE_MOCKS=false
VITE_API_BASE_URL=/api

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

VITE_SARVAM_API_KEY=
VITE_VAPID_PUBLIC_KEY=
