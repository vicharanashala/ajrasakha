# ===========================================
# Ajrasakha Review System Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit your actual .env file to version control
# ===========================================

# ===================
# Application
# ===================
NODE_ENV=development
PORT=8080
APP_PORT=3141
APP_MODULE=all

# URL and CORS
APP_URL=http://localhost:3141
APP_ORIGINS=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173
APP_ROUTE_PREFIX=/api

# Admin password for initial setup
ADMIN_PASSWORD=change_this_secure_password

# ===================
# Database (MongoDB)
# ===================
# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?options
=mongodb+srv://username:passwordDB_URL@cluster.mongodb.net/dbname
DB_NAME=agriai

# ===================
# Firebase (Server-side Admin SDK)
# ===================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ===================
# Firebase Emulators (Development only)
# ===================
# Uncomment these when running Firebase emulators locally
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_EMULATOR_HOST=127.0.0.1:4000
# GCLOUD_PROJECT=your-emulator-project-id

# ===================
# Sentry (Error Tracking)
# ===================
# Get from Sentry dashboard > Project > Settings > Client Keys
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===================
# SMTP (Email Notifications)
# ===================
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password-or-app-password

# ===================
# Google Cloud Platform
# ===================
# Path to GCP service account JSON file (for backup to GCS)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCS bucket name for database backups
# GCP_BACKUP_BUCKET=your-gcs-bucket-name

# ===================
# Feature Flags
# ===================
ENABLE_DB_BACKUP=false
ENABLE_AI_SERVER=true

# ===================
# AI Services
# ===================
# LangGraph Server
AI_SERVER_IP=localhost
AI_SERVER_PORT=9017

# Agent Server
AGENT_SERVER_IP=localhost
AGENT_SERVER_PORT=9017

# OpenAI Server
OPENAI_SERVER_IP=localhost
OPENAI_SERVER_PORT=8080

# GDB Server (Golden Dataset)
GDB_SERVER_IP=localhost
GDB_SERVER_PORT=8110

# WhatsApp Server
WHATSAPP_SERVER_PORT=2026
WHATSAPP_SERVER_URL=http://localhost:2026

# AI Initial Answer Generation
AI_INITIAL_ANSWER_GENERATE_URL=http://localhost:8080/generate-answer

# Proxy for AI requests (optional)
AI_PROXY_ADDRESS=socks5h://localhost:1055

# API Keys for various AI services
GEMMA_API=your-gemma-api-endpoint
GEMMA_API_KEY=your-gemma-api-key
MINIMAX_API=your-minimax-api-endpoint
MINIMAX_API_KEY=your-minimax-api-key
SARVAM_API_KEY=your-sarvam-api-key

# Vicharanashala API Token
VICHARANASHALA_API_TOKEN=your-api-token

# ===================
# LangGraph Server (Alternative)
# ===================
LANGRAPH_SERVER_IP=localhost
LANGRAPH_SERVER_PORT=9017

# ===================
# WhatsApp Integration
# ===================
# Webhook API key for WhatsApp server authentication
WA_WEBHOOK_API_KEY=your-whatsapp-webhook-api-key
WA_WEBHOOK_API_URL=http://localhost:3080/api/webhooks/whatsapp
WA_SEND_MESSAGE_WEBHOOK_API_URL=http://localhost:3080/api/webhooks/send-message

# ===================
# Web Push Notifications
# ===================
# Email for VAPID (must match your push service)
VAPID_EMAIL=mailto:your-email@example.com

# VAPID keys for web push (generate using: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ===================
# Internal API Authentication
# ===================
# Secret key for internal service-to-service authentication
# Generate a secure random string: openssl rand -hex 32
INTERNAL_API_KEY=your-internal-api-key-secret

# ===================
# Plivo (Voice Calling)
# ===================
# WebSocket URL for Plivo streaming (use ngrok for local dev)
PLIVO_STREAM_URL=wss://your-ngrok-url/plivo-stream

# Plivo credentials from Plivo Console
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
PLIVO_NUMBER=+15551234567

# ===================
# Webhook for Web Notifications
# ===================
WEB_WEBHOOK_API_URL=http://localhost:3080/api/webhooks/notifications
WEB_WEBHOOK_API_KEY=your-web-webhook-api-key

# ===================
# LGD Configs (To get states, district and village lists)
# ===================
LGD_API_KEY=<API_KEY>
LGD_VILLAGES_API_URL=https://api.data.gov.in/resource/f17a1608-5f10-4610-bb50-a63c80d83974
LGD_STATES_API_URL=https://api.data.gov.in/resource/a71e60f0-a21d-43de-a6c5-fa5d21600cdb
LGD_DISTRICTS_API_URL=https://api.data.gov.in/resource/37231365-78ba-44d5-ac22-3deec40b9197
LGD_SUBDISTRICTS_API_URL=https://api.data.gov.in/resource/6be51a29-876a-403a-a6da-42fde795e751