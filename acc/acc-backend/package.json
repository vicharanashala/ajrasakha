{
  "name": "acc-backend",
  "version": "1.0.0",
  "description": "ACC Call Center Backend Service",
  "main": "build/index.js",
  "scripts": {
    "start": "node build/index.js",
    "dev": "concurrently \"pnpm run watch:compile\" \"pnpm run watch:build\"",
    "watch:compile": "tsc --watch",
    "watch:build": "nodemon --watch build --ext js --exec \"node build/index.js\"",
    "build": "tsc"
  },
  "imports": {
    "#root/*.js": "./build/*.js",
    "#shared/*.js": "./build/shared/*.js"
  },
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/ws": "^8.18.1",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.3",
    "bson": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "class-validator-jsonschema": "^5.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "firebase-admin": "^13.2.0",
    "inversify": "^7.5.2",
    "mongodb": "^6.17.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.3",
    "openai": "^6.27.0",
    "plivo": "^4.77.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.2",
    "routing-controllers-openapi": "github:adityabmv/routing-controllers-openapi",
    "@scalar/express-api-reference": "^0.8.4",
    "winston": "^3.17.0",
    "ws": "^8.20.0"
  }
}
