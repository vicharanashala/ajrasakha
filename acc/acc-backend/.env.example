NODE_ENV=development
APP_PORT=4001
APP_URL=http://localhost:4001
APP_ROUTE_PREFIX=/api
APP_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:8080,http://localhost:8081

# Database Configuration
DB_URL=mongodb://localhost:27017
DB_NAME=agriai

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=dummy-project-id
FIREBASE_CLIENT_EMAIL=dummy-client@email.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Plivo API Credentials
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_NUMBER=+15551234567
PLIVO_STREAM_URL=wss://your-domain.com/plivo-stream

# Plivo Endpoint Usernames for Call Agents (agent_1, agent_2, etc.)
PLIVO_ENDPOINT_USERNAME_AGENT_1=sip:agent_1_username@phone.plivo.com
PLIVO_ENDPOINT_USERNAME_AGENT_2=sip:agent_2_username@phone.plivo.com

# AI / LangGraph Integration (ACC Agent)
ACC_AGENT_BASE_URL=http://localhost:9017
ACC_AGENT_ASSISTANT_ID=your_langgraph_assistant_id
ACC_AGENT_TIMEOUT=10000

# Sarvam API Key
SARVAM_API_KEY=your_sarvam_api_key

# Fast2SMS API Key
FAST2SMS_API_KEY=your_fast2sms_api_key
