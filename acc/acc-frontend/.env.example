# ===================================================
# Agricultural Call Center (ACC) Frontend Env Configuration
# ===================================================
# Copy this file to .env and fill in your values
# ===================================================

# Base URL for the ACC Backend microservice (running on port 4001)
VITE_API_BASE_URL=http://localhost:4001/api

# ====================
# Firebase Client SDK Configuration
# ====================
# Must match the same Firebase Project as the monolithic Review System
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ====================
# Plivo Audio & Call Agent Configuration
# ====================
# Real-time WebSocket Plivo audio transcription stream endpoint
VITE_PLIVO_STREAM_URL=wss://your-domain.com/plivo-stream

# Credentials for Plivo SIP Endpoints used by browser WebRTC client.
# Register SIP credentials in Plivo Console. Agent numbers are agent_1, agent_2...
VITE_PLIVO_AGENT_1_USERNAME=sip:agent_1_username@phone.plivo.com
VITE_PLIVO_AGENT_1_PASSWORD=your_agent_1_password

VITE_PLIVO_AGENT_2_USERNAME=sip:agent_2_username@phone.plivo.com
VITE_PLIVO_AGENT_2_PASSWORD=your_agent_2_password
